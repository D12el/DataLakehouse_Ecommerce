# Trino environment variables
# Copy this file to `.env` and fill the values. The `.env` file is gitignored.

# Catalog management mode (e.g. dynamic, static)
CATALOG_MANAGEMENT=dynamic

# Shared secret for internal communication between coordinator and workers.
# REQUIRED when authentication is enabled. Must be identical for all nodes.
# Generate with: openssl rand -base64 32
TRINO_SHARED_SECRET=replace-me-with-a-strong-random-value
